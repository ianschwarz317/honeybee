# ============================================================
# Honeybee environment variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-side only — NEVER prefix with NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Stripe (test keys for development) ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- AI service ----
ANTHROPIC_API_KEY=sk-ant-...
# Future: swap to self-hosted endpoint
# AI_SERVICE_URL=https://your-self-hosted-model.com/v1

# ---- Email (Resend) ----
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@seehoneybee.com

# ---- Apple Wallet ----
# APPLE_PASS_TYPE_ID=pass.com.seehoneybee.pet
# APPLE_TEAM_ID=YOUR_TEAM_ID
# APPLE_PASS_CERTIFICATE_PATH=./certs/pass.pem
# APPLE_PASS_KEY_PATH=./certs/pass.key

# ---- Google Wallet ----
# GOOGLE_WALLET_ISSUER_ID=YOUR_ISSUER_ID
# GOOGLE_WALLET_SERVICE_ACCOUNT_KEY=./certs/google-sa.json

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SCAN_URL=http://localhost:3000/scan
# Production:
# NEXT_PUBLIC_APP_URL=https://app.seehoneybee.com
# NEXT_PUBLIC_SCAN_URL=https://scan.seehoneybee.com
